# API key auth is enabled by default.
FPDS_ANALYTICS_REQUIRE_AUTH=1

# Prefer SHA-256 hashes of API keys in production.
# Generate with: printf '%s' "$FPDS_API_KEY" | sha256sum
FPDS_ANALYTICS_API_KEY_HASHES=replace_me_sha256_hex

# Plaintext keys are supported for local testing only.
# FPDS_ANALYTICS_API_KEYS=fpds_live_replace_me

# CORS is disabled by default. Set explicit browser origins only if needed.
FPDS_ANALYTICS_ALLOWED_ORIGINS=https://example.com
# FPDS_ANALYTICS_ALLOW_ALL_ORIGINS=1

# Rate limiting is enabled by default. Use Redis for multi-instance deployments.
FPDS_ANALYTICS_RATE_LIMIT_ENABLED=1
# FPDS_ANALYTICS_REDIS_URL=redis://localhost:6379/0
FPDS_ANALYTICS_API_KEY_RATE_LIMIT_REQUESTS=120
FPDS_ANALYTICS_API_KEY_RATE_LIMIT_WINDOW_SECONDS=60
FPDS_ANALYTICS_PUBLIC_RATE_LIMIT_REQUESTS=300
FPDS_ANALYTICS_PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
FPDS_ANALYTICS_UNAUTH_DATA_RATE_LIMIT_REQUESTS=30
FPDS_ANALYTICS_UNAUTH_DATA_RATE_LIMIT_WINDOW_SECONDS=60

# Prefer a DSN that points at the restricted fpds_analytics_api_readonly role.
ANALYTICS_DATABASE_URL=postgresql://fpds_analytics_api_readonly:replace_me@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Alternative component-based connection settings used only if no DSN is set.
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=fpds_analytics_api_readonly
DB_PASS=replace_me
